<Window x:Class="PiStats.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:PiStats.Assets"
        Title="Pi Stats"
        Width="380" Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal">
    <Window.Resources>
        <!-- Thin, dark, minimal scrollbar that fits the glass panel -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border CornerRadius="3" Margin="2,0"
                                                        Background="#40FFFFFF" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="14"
            Background="#E61E1E1E"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="14,11,12,11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0" Data="{x:Static assets:PiLogo.Geometry}"
                      Fill="White" Stretch="Uniform" Width="20" Height="20"
                      VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Pi Stats" Foreground="White" FontSize="14" FontWeight="Bold" />
                    <TextBlock x:Name="SubtitleText" Foreground="#99FFFFFF" FontSize="10" Text="Loading…" />
                </StackPanel>

                <Border Grid.Column="2" x:Name="RangeContainer"
                        CornerRadius="7" Background="#10FFFFFF" Padding="2"
                        VerticalAlignment="Center" Margin="0,0,6,0">
                    <StackPanel x:Name="RangePanel" Orientation="Horizontal" />
                </Border>

                <Button Grid.Column="3" x:Name="RefreshButton" Style="{StaticResource Flat}"
                        Width="26" Height="26" HorizontalContentAlignment="Center"
                        Foreground="#CCFFFFFF"
                        ToolTip="Rescan sessions" Click="RefreshButton_Click">
                    <TextBlock Text="&#x21BB;" FontSize="15" />
                </Button>

                <Button Grid.Column="4" x:Name="SettingsButton" Style="{StaticResource Flat}"
                        Width="26" Height="26" HorizontalContentAlignment="Center"
                        Foreground="#CCFFFFFF"
                        ToolTip="Settings" Click="SettingsButton_Click">
                    <TextBlock Text="&#x2699;" FontSize="15" />
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#1AFFFFFF" />

            <!-- Tab bar -->
            <StackPanel Grid.Row="2" x:Name="TabPanel" Orientation="Horizontal"
                        Margin="8,0,8,0" />

            <Border Grid.Row="3" Height="1" Background="#1AFFFFFF" />

            <!-- Body -->
            <Grid Grid.Row="4">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Local / Remote source switch (shown when remote is configured) -->
                <Border x:Name="RemoteBar" Grid.Row="0" Visibility="Collapsed"
                        Padding="14,7" Background="#0AFFFFFF">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SourceLabel" Grid.Column="0" Foreground="#99FFFFFF"
                                   FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <Border Grid.Column="1" CornerRadius="6" Background="#10FFFFFF" Padding="2">
                            <StackPanel x:Name="SourceToggle" Orientation="Horizontal" />
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <ProgressBar x:Name="LoadProgress" Width="180" Height="4" Minimum="0" Maximum="1" />
                    <TextBlock x:Name="LoadingText" Foreground="#99FFFFFF" FontSize="11"
                               Margin="0,10,0,0" HorizontalAlignment="Center" Text="Reading Pi sessions…" />
                </StackPanel>

                <ScrollViewer x:Name="BodyScroll" VerticalScrollBarVisibility="Auto" Padding="0">
                    <StackPanel x:Name="BodyHost" Margin="14" />
                </ScrollViewer>
                </Grid>
            </Grid>

            <Border Grid.Row="5" Height="1" Background="#1AFFFFFF" />

            <!-- Footer -->
            <Button Grid.Row="6" x:Name="QuitButton" Style="{StaticResource Flat}"
                    Margin="6" Padding="10,7" HorizontalContentAlignment="Left"
                    Foreground="#DDFFFFFF" Click="QuitButton_Click">
                <TextBlock Text="Quit" FontSize="12" />
            </Button>
        </Grid>
    </Border>
</Window>
