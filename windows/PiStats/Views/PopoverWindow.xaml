<Window x:Class="PiStats.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:PiStats.Assets"
        Title="Pi Stats"
        Width="380" Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True">
    <!-- Rounded translucent container (macOS NSVisualEffectView equivalent) -->
    <Border CornerRadius="14"
            Background="#CC1E1E1E"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid>
            <!-- Placeholder header for Step 1 -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Top" HorizontalAlignment="Left"
                        Margin="14,12,0,0">
                <Path Data="{x:Static assets:PiLogo.Geometry}"
                      Fill="White" Stretch="Uniform"
                      Width="20" Height="20" />
                <TextBlock Text="Pi Stats"
                           Foreground="White"
                           FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center"
                           Margin="9,0,0,0" />
            </StackPanel>

            <TextBlock Text="Windows port — scaffold ready ✓"
                       Foreground="#99FFFFFF"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center" />
        </Grid>
    </Border>
</Window>
