<Window x:Class="PiStats.Views.PopoverWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:assets="clr-namespace:PiStats.Assets"
        Title="Pi Stats"
        Width="380" Height="560"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        TextOptions.TextFormattingMode="Ideal"
        UseLayoutRounding="True">
    <Border CornerRadius="14"
            Background="#E61E1E1E"
            BorderBrush="#22FFFFFF"
            BorderThickness="1"
            SnapsToDevicePixels="True">
        <Grid Margin="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="14,12,12,11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Path Grid.Column="0"
                      Data="{x:Static assets:PiLogo.Geometry}"
                      Fill="White" Stretch="Uniform"
                      Width="20" Height="20" VerticalAlignment="Center" />

                <StackPanel Grid.Column="1" Margin="9,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="Pi Stats" Foreground="White"
                               FontSize="14" FontWeight="Bold" />
                    <TextBlock x:Name="SubtitleText" Foreground="#99FFFFFF"
                               FontSize="10" Text="Loading…" />
                </StackPanel>

                <Button Grid.Column="2" x:Name="RefreshButton"
                        Width="26" Height="26" Padding="0"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#CCFFFFFF" Cursor="Hand"
                        ToolTip="Rescan sessions"
                        Click="RefreshButton_Click">
                    <TextBlock Text="&#x21BB;" FontSize="15" />
                </Button>
            </Grid>

            <Border Grid.Row="1" Height="1" Background="#1AFFFFFF" />

            <!-- Body (Step 4: live summary; full tabs come in Step 5) -->
            <Grid Grid.Row="2">
                <!-- Loading state -->
                <StackPanel x:Name="LoadingPanel" VerticalAlignment="Center"
                            HorizontalAlignment="Center" Visibility="Collapsed">
                    <ProgressBar x:Name="LoadProgress" Width="180" Height="4"
                                 Minimum="0" Maximum="1" />
                    <TextBlock x:Name="LoadingText" Foreground="#99FFFFFF" FontSize="11"
                               Margin="0,10,0,0" HorizontalAlignment="Center"
                               Text="Reading Pi sessions…" />
                </StackPanel>

                <!-- Content -->
                <StackPanel x:Name="ContentPanel" Margin="14" VerticalAlignment="Top">
                    <UniformGrid Columns="2" Rows="3" x:Name="CardsGrid" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="3" Height="1" Background="#1AFFFFFF" />

            <!-- Footer -->
            <Button Grid.Row="4" x:Name="QuitButton"
                    Margin="6" Padding="10,7"
                    HorizontalContentAlignment="Left"
                    Background="Transparent" BorderThickness="0"
                    Foreground="#DDFFFFFF" Cursor="Hand"
                    Click="QuitButton_Click">
                <TextBlock Text="Quit" FontSize="12" />
            </Button>
        </Grid>
    </Border>
</Window>
