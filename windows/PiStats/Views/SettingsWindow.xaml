<Window x:Class="PiStats.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Pi Stats Settings"
        Width="580" Height="460"
        MinWidth="540" MinHeight="420"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="170" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ListBox x:Name="Sidebar" Grid.Column="0" BorderThickness="0"
                 Background="#F3F3F3" Padding="6"
                 SelectionChanged="Sidebar_SelectionChanged">
            <ListBoxItem Content="Menu Bar" />
            <ListBoxItem Content="General" />
            <ListBoxItem Content="Remote" />
            <ListBoxItem Content="About" />
        </ListBox>

        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel x:Name="PaneHost" Margin="24" />
        </ScrollViewer>
    </Grid>
</Window>
